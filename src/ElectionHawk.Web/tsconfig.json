{
  "compilerOptions": {
    "baseUrl": "ClientApp",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    //"noUnusedLocals": true,
    //"noImplicitAny": true,
    //"noImplicitReturns": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "target": "es5",
    "types": [ "webpack-env" ],
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es6",
      "dom"
    ],
    "module": "es2015",
    "paths": {
      "@app/*": [
        "app/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "compiled"
  ]
}
